# ── LLM CONFIGURATION ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# ── DATABASE CONFIGURATION ─────────────────────────────────────────────
# PostgreSQL database URL. For production use dynamic config.
# Local Docker development: postgresql+asyncpg://nexus:nexus_pass@localhost:5433/nexus
DATABASE_URL=postgresql://nexus:nexus_pass@localhost:5433/nexus

# ── CACHE & REDIS CONFIGURATION ─────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── VECTOR DB CONFIGURATION ────────────────────────────────────────────
# Qdrant host & port.
QDRANT_HOST=localhost
QDRANT_PORT=6345
QDRANT_API_KEY=

# ── RERANKER CONFIGURATION ─────────────────────────────────────────────
# Cohere API Key for document reranking (free tier keys work)
COHERE_API_KEY=your_cohere_api_key_here

# ── JWT AUTH CONFIGURATION ─────────────────────────────────────────────
JWT_SECRET=your_jwt_signing_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── OBSERVABILITY CONFIGURATION ────────────────────────────────────────
# Langsmith or Langfuse configurations.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexus-ai

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── CORS ORIGINS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
